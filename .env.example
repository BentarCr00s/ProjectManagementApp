# Environment Variables - ClickUp Replica
# Copy this file to .env and fill in your values

# Database (use file:local.db for local dev without Turso account)
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Session
SESSION_SECRET=clickup-replica-super-secret-change-in-prod-2024

# Server
PORT=3000
NODE_ENV=development
