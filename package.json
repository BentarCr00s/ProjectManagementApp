{
  "name": "tasksync",
  "version": "1.0.0",
  "description": "TaskSync project management app built with Express, Pug, and Turso DB",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/styles.css",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/css/styles.css --watch",
    "migrate": "node src/config/migrate.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "setup": "npm run migrate && npm run build:css"
  },
  "dependencies": {
    "@tursodatabase/database": "^0.1.0",
    "bcrypt": "^5.1.1",
    "connect-sqlite3": "^0.9.15",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pug": "^3.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "autoprefixer": "^10.4.19",
    "jest": "^29.7.0",
    "nodemon": "^3.1.3",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.4"
  }
}
