extends ../layouts/main.pug
include ../mixins/taskCard.pug

block content
  .h-full.flex.flex-col

    //- Filter Toolbar
    .flex.items-center.gap-3.px-6.py-2.border-b.border-gray-200.bg-white.flex-shrink-0.flex-wrap
      span.text-xs.font-semibold.text-gray-500.uppercase.tracking-wide Filters:
      select#board-filter-status.text-xs.border.border-gray-200.rounded.px-2.py-1.bg-white.focus_outline-none.focus_border-brand-400.cursor-pointer(onchange="applyBoardFilters()")
        option(value="ALL") All Status
        option(value="TODO") Todo
        option(value="IN_PROGRESS") In Progress
        option(value="REVIEW") Review
        option(value="DONE") Done
      select#board-filter-priority.text-xs.border.border-gray-200.rounded.px-2.py-1.bg-white.focus_outline-none.focus_border-brand-400.cursor-pointer(onchange="applyBoardFilters()")
        option(value="ALL") All Priority
        option(value="urgent") Urgent
        option(value="high") High
        option(value="normal") Normal
        option(value="low") Low
      select#board-filter-assignee.text-xs.border.border-gray-200.rounded.px-2.py-1.bg-white.focus_outline-none.focus_border-brand-400.cursor-pointer(onchange="applyBoardFilters()")
        option(value="ALL") All Assignees
        if members && members.length > 0
          each member in members
            option(value=member.id)= member.name
      button.text-xs.px-3.py-1.border.border-gray-200.rounded.bg-white.text-gray-500.hover_bg-gray-100.hover_text-gray-700.transition-colors(onclick="clearBoardFilters()") Clear Filters

    //- Board Content
    .flex-1.p-6.overflow-x-auto.overflow-y-hidden.bg-surface-secondary
      .flex.h-full.gap-6.items-start

        each statusGroup, statusName in boardData
          .kanban-column(data-status=statusName)
            //- Column Header with List Options dropdown
            .kanban-column-header
              .flex.items-center.gap-2.flex-1
                span(class=`w-3 h-3 rounded-full bg-${statusName === 'TODO' ? 'gray-400' : statusName === 'IN_PROGRESS' ? 'blue-500' : statusName === 'REVIEW' ? 'purple-500' : 'green-500'}`)
                h3.font-semibold.text-gray-700.text-sm= statusName.replace('_', ' ')
                span.col-count-badge.text-xs.font-medium.text-gray-400.bg-gray-200.px-2.py-0_5.rounded-full= statusGroup.length

            .kanban-drop-zone.h-full.pb-20
              if statusGroup.length > 0
                each task in statusGroup
                  +taskCard(task)
              else
                .empty-column-state.flex.flex-col.items-center.justify-center.py-8.px-4.text-center.border-2.border-dashed.border-gray-200.rounded-xl.mt-2
                  .text-2xl.mb-2 ✨
                  p.text-xs.text-gray-500.mb-3 No tasks here
                  button.text-xs.px-3.py-1_5.bg-brand-600.text-white.rounded-md.hover_bg-brand-700.transition-colors(
                    x-data
                    @click.stop="$dispatch('open-create-task')"
                  ) + Add Task

  script(src="/js/board.js")

  script.
    function applyBoardFilters() {
      const status = document.getElementById('board-filter-status').value;
      const priority = document.getElementById('board-filter-priority').value;
      const assignee = document.getElementById('board-filter-assignee').value;
      const cards = document.querySelectorAll('.task-card');

      cards.forEach(card => {
        const matchStatus = status === 'ALL' || card.dataset.status === status;
        const matchPriority = priority === 'ALL' || card.dataset.priority === priority;
        const matchAssignee = assignee === 'ALL' || card.dataset.assigneeId === assignee;
        card.style.display = (matchStatus && matchPriority && matchAssignee) ? '' : 'none';
      });

      // Update counts after filtering
      document.querySelectorAll('.kanban-column').forEach(col => {
        const visible = col.querySelectorAll('.task-card:not([style*="display: none"])').length;
        const badge = col.querySelector('.col-count-badge');
        if (badge) badge.textContent = visible;
      });
    }

    function clearBoardFilters() {
      document.getElementById('board-filter-status').value = 'ALL';
      document.getElementById('board-filter-priority').value = 'ALL';
      document.getElementById('board-filter-assignee').value = 'ALL';
      applyBoardFilters();
    }
