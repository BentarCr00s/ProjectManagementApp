//- This is meant to be loaded via AJAX/Fetch into the task modal
.flex.h-full
  //- Left Column: Task Details
  .w-2_3.p-8.border-r.border-gray-200.overflow-y-auto.scrollbar-thin
    .flex.items-center.gap-3.mb-6
      span.text-xs.font-medium.text-gray-500= task.id.substring(0,8).toUpperCase()
      span(class=`status-${task.status.toLowerCase().replace('_','')} px-2 py-0_5 rounded text-[10px]`)= task.status.replace('_', ' ')
      //- Delete Task Button
      button.ml-auto.flex.items-center.gap-1.px-3.py-1.text-xs.font-medium.text-red-600.border.border-red-200.rounded-md.hover_bg-red-50.hover_border-red-400.transition-colors(
        id="delete-task-btn"
        data-task-id=task.id
        title="Delete this task"
      )
        svg.w-3_5.h-3_5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16")
        | Delete Task

    h2.text-2xl.font-bold.text-gray-900.mb-6= task.title

    .grid.grid-cols-2.gap-y-6.gap-x-8.mb-8
      div
        label.text-xs.font-medium.text-gray-500.uppercase Assignee
        .flex.items-center.gap-2.mt-2
          if task.assignee_name
            .avatar(style=`background-color: ${task.assignee_color}`)
              | #{task.assignee_name.charAt(0).toUpperCase()}
            span.text-sm.font-medium= task.assignee_name
          else
            span.text-sm.text-gray-500 Unassigned

      div
        label.text-xs.font-medium.text-gray-500.uppercase Priority
        .mt-2
          span(class=`priority-${task.priority} font-semibold text-sm capitalize`)= task.priority

      div
        label.text-xs.font-medium.text-gray-500.uppercase Due Date
        .mt-2.text-sm.font-medium= task.due_date ? new Date(task.due_date).toLocaleDateString() : 'None'

      div
        label.text-xs.font-medium.text-gray-500.uppercase Time Tracked
        .mt-2.flex.items-center.gap-2
          span#timer-display.text-sm.font-medium(data-initial=task.time_tracked data-active=activeTimer ? 'true' : 'false')
            | #{Math.floor(task.time_tracked / 3600)}h #{Math.floor((task.time_tracked % 3600) / 60)}m #{task.time_tracked % 60}s
          button#toggle-timer.btn-ghost.px-2.py-1.text-xs(data-task-id=task.id data-active=activeTimer ? 'true' : 'false')
            if activeTimer
              span.text-red-500 ⏹ Stop
            else
              span.text-brand-600 ▶ Start

    .mb-8
      label.text-xs.font-medium.text-gray-500.uppercase.block.mb-3 Description
      if task.description
        .text-sm.text-gray-700.whitespace-pre-wrap= task.description
      else
        p.text-sm.text-gray-400.italic No description provided.

    //- Subtasks Section
    .mb-8
      .flex.items-center.justify-between.mb-3
        label.text-xs.font-medium.text-gray-500.uppercase Subtasks
        span.text-xs.text-gray-400(id="subtask-count")
          if task.subtasks && task.subtasks.length > 0
            | #{task.subtasks.filter(s => s.status === 'DONE').length}/#{task.subtasks.length} completed
          else
            | 0/0 completed

      //- Subtask List
      #subtasks-list.space-y-2.mb-3
        if task.subtasks && task.subtasks.length > 0
          each subtask in task.subtasks
            .subtask-item.flex.items-center.gap-3.p-2.rounded-lg.hover_bg-gray-50.group(
              data-subtask-id=subtask.id
              data-status=subtask.status
            )
              button.subtask-toggle.w-5.h-5.rounded.border-2.flex.items-center.justify-center.flex-shrink-0.transition-colors(
                class=subtask.status === 'DONE' ? 'border-green-500 bg-green-500 text-white' : 'border-gray-300 hover_border-brand-400'
                data-task-id=task.id
                data-subtask-id=subtask.id
                data-current-status=subtask.status
                title="Toggle status"
              )
                if subtask.status === 'DONE'
                  svg.w-3.h-3(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7")
              span.flex-1.text-sm(class=subtask.status === 'DONE' ? 'line-through text-gray-400' : 'text-gray-700')= subtask.title
              button.subtask-delete.opacity-0.group-hover_opacity-100.p-1.text-gray-400.hover_text-red-500.transition-all.rounded(
                data-task-id=task.id
                data-subtask-id=subtask.id
                title="Delete subtask"
              )
                svg.w-3_5.h-3_5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16")
        else
          p#subtasks-empty.text-xs.text-gray-400.italic.py-1 No subtasks yet.

      //- Add Subtask Inline Form
      form#add-subtask-form.flex.items-center.gap-2(data-task-id=task.id)
        input#subtask-input.flex-1.text-sm.border.border-gray-200.rounded-md.px-3.py-1_5.focus_outline-none.focus_border-brand-400.focus_ring-1.focus_ring-brand-400(
          type="text"
          placeholder="Add a subtask..."
          autocomplete="off"
        )
        button.px-3.py-1_5.text-xs.font-medium.bg-brand-600.text-white.rounded-md.hover_bg-brand-700.transition-colors(type="submit") Add

  //- Right Column: Activity & Comments
  .w-1_3.flex.flex-col.bg-gray-50
    .p-4.border-b.border-gray-200
      h3.font-semibold.text-gray-800 Activity

    //- Comments List
    #comments-list.flex-1.overflow-y-auto.p-4.space-y-4
      if comments && comments.length > 0
        each comment in comments
          .comment-item.flex.gap-3(data-comment-id=comment.id)
            .avatar.w-8.h-8.flex-shrink-0(style=`background-color: ${comment.avatar_color}`)
              | #{comment.user_name.charAt(0).toUpperCase()}
            .flex-1.min-w-0
              .flex.items-baseline.gap-2.mb-1
                span.text-sm.font-semibold.text-gray-900= comment.user_name
                span(class="text-[10px] text-gray-500")= new Date(comment.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})
                if currentUser && comment.user_id === currentUser.id
                  .flex.items-center.gap-1.ml-auto
                    button.comment-edit-btn.p-0_5.text-gray-400.hover_text-brand-500.transition-colors.rounded(
                      data-task-id=task.id
                      data-comment-id=comment.id
                      title="Edit comment"
                    )
                      svg.w-3_5.h-3_5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z")
                    button.comment-delete-btn.p-0_5.text-gray-400.hover_text-red-500.transition-colors.rounded(
                      data-task-id=task.id
                      data-comment-id=comment.id
                      title="Delete comment"
                    )
                      svg.w-3_5.h-3_5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16")
              //- Static view
              p.comment-text.text-sm.text-gray-700.bg-white.p-2.rounded-lg.shadow-sm.border.border-gray-100= comment.content
              //- Edit form (hidden by default)
              .comment-edit-form.hidden
                textarea.comment-edit-textarea.w-full.text-sm.border.border-brand-300.rounded-lg.px-3.py-2.resize-none.focus_outline-none.focus_ring-1.focus_ring-brand-400(rows="2")= comment.content
                .flex.justify-end.gap-2.mt-1
                  button.comment-edit-cancel.text-xs.px-2.py-1.text-gray-500.hover_text-gray-700.border.border-gray-200.rounded Cancel
                  button.comment-edit-save.text-xs.px-2.py-1.bg-brand-600.text-white.rounded.hover_bg-brand-700(
                    data-task-id=task.id
                    data-comment-id=comment.id
                  ) Save
      else
        p.text-xs.text-center.text-gray-500.mt-4 No activity yet.

    //- Comment Input
    .p-4.border-t.border-gray-200.bg-white
      form#comment-form(@submit.prevent="postComment")
        input#comment-task-id(type="hidden" value=task.id)
        textarea#comment-input.form-input.text-sm.resize-none(rows="2" placeholder="Write a comment..." required)
        .flex.justify-end.mt-2
          button.btn-primary.px-3.py-1_5.text-xs(type="submit") Send
