doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title #{title} | ClickUp Replica
    link(rel="stylesheet", href="/css/styles.css")
    //- AlpineJS for simple interactions (dropdowns, modals)
    script(defer, src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js")
  body.bg-surface-secondary.text-gray-800.font-sans.antialiased.overflow-hidden

    //- Toast Container
    div(id="toast-container" class="fixed bottom-6 right-6 z-[100] flex flex-col gap-2")

    .flex.h-screen.w-full
      //- Sidebar Navigation
      aside.sidebar
        .p-4.border-b.border-sidebar-border.flex.justify-between.items-center
          .font-bold.text-lg.text-white.flex.items-center.gap-2
            span.text-brand-500.text-xl ⬡
            | ClickUp Clone

        .flex-1.overflow-y-auto.scrollbar-thin.p-3
          if currentWorkspace
            .mb-6
              //- Workspace name + gear icon
              .flex.items-center.justify-between.px-2.mb-2
                .text-xs.font-semibold.uppercase.tracking-wider.text-sidebar-text= currentWorkspace.name
                .flex.items-center.gap-1
                  //- Gear icon → workspace settings modal
                  button.p-1.rounded.text-sidebar-text.hover_text-white.hover_bg-sidebar-hover.transition-colors(
                    onclick="openWorkspaceSettings()"
                    title="Workspace settings"
                  )
                    svg.w-3_5.h-3_5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                      path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z")
                      circle(cx="12" cy="12" r="3" stroke-linecap="round" stroke-linejoin="round" stroke-width="2")

              if workspaceLists && workspaceLists.length > 0
                ul.space-y-1
                  each list in workspaceLists
                    li.relative.group-list(x-data="{ showMenu: false }")
                      .flex.items-center.rounded-md(class=`${currentList && currentList.id === list.id ? 'bg-sidebar-active' : ''}`)
                        a(href=`/workspaces/${currentWorkspace.id}/lists/${list.id}` class=`flex-1 flex items-center gap-2 px-2 py-1.5 hover:bg-sidebar-hover hover:text-white transition-colors ${currentList && currentList.id === list.id ? 'text-white font-medium' : ''}`)
                          span.text-brand-400 •
                          span.flex-1.truncate= list.name
                          //- Task count badge
                          if list.task_count !== undefined && list.task_count !== null
                            span.text-xs.bg-sidebar-hover.text-gray-400.px-1.py-0.rounded-full= list.task_count
                        //- "..." menu button
                        button.px-1.py-1_5.text-sidebar-text.hover_text-white.opacity-0.group-list-hover_opacity-100.transition-all.focus_opacity-100(
                          @click.prevent="showMenu = !showMenu"
                          title="List options"
                        )
                          svg.w-4.h-4(fill="currentColor" viewBox="0 0 24 24")
                            circle(cx="12" cy="5" r="1.5")
                            circle(cx="12" cy="12" r="1.5")
                            circle(cx="12" cy="19" r="1.5")

                      //- Dropdown menu
                      .absolute.left-full.top-0.ml-1.z-50.bg-white.border.border-gray-200.rounded-lg.shadow-lg.py-1.min-w-36(x-show="showMenu" @click.outside="showMenu = false" x-cloak style="display:none")
                        button.flex.items-center.gap-2.w-full.px-3.py-2.text-sm.text-gray-700.hover_bg-gray-50.transition-colors(
                          onclick=`renameList('${list.id}', '${list.name.replace(/'/g, "\\'")}'); this.closest('[x-data]').__x.$data.showMenu = false`
                        )
                          svg.w-4.h-4.text-gray-400(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z")
                          | Rename list
                        button.flex.items-center.gap-2.w-full.px-3.py-2.text-sm.text-red-600.hover_bg-red-50.transition-colors(
                          onclick=`deleteList('${list.id}'); this.closest('[x-data]').__x.$data.showMenu = false`
                        )
                          svg.w-4.h-4(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16")
                          | Delete list
              else
                .px-2.py-3.text-sm.text-center.bg-sidebar-hover.rounded-lg.border.border-dashed.border-sidebar-border
                  p.mb-2 No lists found
                  form(action=`/workspaces/${currentWorkspace.id}/lists` method="POST")
                    input(type="hidden" name="name" value="General Task List")
                    button.text-brand-400.hover_text-brand-300.font-medium.text-xs(type="submit") + Create Default List
          else
            //- Dashboard view
            .text-xs.font-semibold.uppercase.tracking-wider.text-sidebar-text.mb-2.px-2 Workspaces
            if workspaces && workspaces.length > 0
              ul.space-y-1
                each ws in workspaces
                  li
                    a(href=`/workspaces/${ws.id}` class="flex items-center gap-2 px-2 py-1.5 rounded-md hover:bg-sidebar-hover hover:text-white transition-colors")
                      span 🏢
                      | #{ws.name}
            else
              .px-2.py-2.text-sm No workspaces

        .p-4.border-t.border-sidebar-border
          .flex.items-center.gap-3
            .avatar(style=`background-color: ${user.avatar_color}`)
              | #{user.name.charAt(0).toUpperCase()}
            .flex-1.min-w-0
              .text-sm.font-medium.text-white.truncate= user.name
              a.text-xs.hover_text-white.transition-colors(href="/logout") Logout

      //- Main Content Area
      main.flex-1.flex.flex-col.ml-60.bg-surface-secondary.relative
        //- Top Header
        header.bg-white.border-b.border-gray-200.h-14.flex.items-center.px-6.justify-between.flex-shrink-0
          .flex.items-center.gap-4
            if currentList
              .flex.items-center.gap-2.relative(x-data="{ showListMenu: false }")
                h1.text-xl.font-semibold.text-gray-800= currentList.name
                //- List options "⋯" button
                button.p-1.rounded.text-gray-400.hover_text-gray-600.hover_bg-gray-100.transition-colors(
                  @click.stop="showListMenu = !showListMenu"
                  title="List options"
                )
                  svg.w-4.h-4(fill="currentColor" viewBox="0 0 24 24")
                    circle(cx="5" cy="12" r="1.5")
                    circle(cx="12" cy="12" r="1.5")
                    circle(cx="19" cy="12" r="1.5")
                //- Dropdown
                .absolute.left-0.top-full.mt-1.z-50.bg-white.border.border-gray-200.rounded-lg.shadow-lg.py-1.min-w-40(x-show="showListMenu" @click.outside="showListMenu = false" x-cloak style="display:none")
                  button.flex.items-center.gap-2.w-full.px-3.py-2.text-sm.text-gray-700.hover_bg-gray-50.transition-colors(
                    onclick=`renameList('${currentList.id}', '${currentList.name.replace(/'/g, "\\'")}'); this.closest('[x-data]').__x.$data.showListMenu = false`
                  )
                    svg.w-4.h-4.text-gray-400(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                      path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z")
                    | Rename list
                  button.flex.items-center.gap-2.w-full.px-3.py-2.text-sm.text-red-600.hover_bg-red-50.transition-colors(
                    onclick=`deleteList('${currentList.id}'); this.closest('[x-data]').__x.$data.showListMenu = false`
                  )
                    svg.w-4.h-4(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                      path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16")
                    | Delete list

              //- View Switcher Tabs
              .flex.items-center.ml-6.bg-surface-secondary.p-1.rounded-lg
                a(href=`/workspaces/${currentWorkspace.id}/lists/${currentList.id}/list` class=`px-3 py-1 text-sm font-medium rounded-md transition-all ${viewType === 'list' ? 'bg-white shadow-sm text-brand-600' : 'text-gray-500 hover:text-gray-700'}`) List
                a(href=`/workspaces/${currentWorkspace.id}/lists/${currentList.id}/board` class=`px-3 py-1 text-sm font-medium rounded-md transition-all ${viewType === 'board' ? 'bg-white shadow-sm text-brand-600' : 'text-gray-500 hover:text-gray-700'}`) Board
            else
              h1.text-xl.font-semibold.text-gray-800= title

          .flex.items-center.gap-3
            button.p-2.text-gray-400.hover_bg-gray-100.rounded-full.transition-colors
              svg.w-5.h-5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9")

            if currentList
              button.btn-primary(x-data @click="$dispatch('open-create-task')")
                span +
                | New Task

        //- Page Content
        .flex-1.overflow-hidden
          block content

    //- Create Task Modal Template (AlpineJS controlled)
    if currentList
      div(x-data="{ open: false, title: '', description: '', priority: 'normal' }"
          @open-create-task.window="open = true; setTimeout(() => $refs.titleInput.focus(), 50)"
          x-show="open"
          x-cloak
          class="fixed inset-0 z-50 overflow-y-auto"
          aria-labelledby="modal-title" role="dialog" aria-modal="true" style="display: none;")
        .flex.items-end.justify-center.min-h-screen.pt-4.px-4.pb-20.text-center.sm_block.sm_p-0
          .fixed.inset-0.bg-gray-500.bg-opacity-75.transition-opacity(x-show="open" x-transition.opacity @click="open = false" aria-hidden="true")
          span.hidden.sm_inline-block.sm_align-middle.sm_h-screen(aria-hidden="true") &#8203;

          .inline-block.align-bottom.bg-white.rounded-xl.text-left.overflow-hidden.shadow-modal.transform.transition-all.sm_my-8.sm_align-middle.sm_max-w-lg.sm_w-full(x-show="open" x-transition)
            form(@submit.prevent="createTask")
              .bg-white.px-4.pt-5.pb-4.sm_p-6.sm_pb-4
                h3#modal-title.text-lg.leading-6.font-medium.text-gray-900.mb-4 Create New Task

                .space-y-4
                  div
                    input.form-input.text-lg.font-medium.border-none.px-0.focus_ring-0(type="text" x-model="title" x-ref="titleInput" placeholder="Task name" required)
                  div
                    textarea.form-input.border-none.px-0.focus_ring-0.resize-none(rows="3" x-model="description" placeholder="Description (optional)")

                  .flex.gap-4
                    div.w-1/2
                      label.text-xs.font-medium.text-gray-500 Priority
                      select.form-select.mt-1(x-model="priority")
                        option(value="urgent") 🔴 Urgent
                        option(value="high") 🟠 High
                        option(value="normal" selected) 🔵 Normal
                        option(value="low") ⚪ Low

            .bg-gray-50.px-4.py-3.sm_px-6.sm_flex.sm_flex-row-reverse
              button.w-full.inline-flex.justify-center.rounded-md.border.border-transparent.shadow-sm.px-4.py-2.bg-brand-600.text-base.font-medium.text-white.hover_bg-brand-700.focus_outline-none.focus_ring-2.focus_ring-offset-2.focus_ring-brand-500.sm_ml-3.sm_w-auto.sm_text-sm(type="submit") Create Task
              button.mt-3.w-full.inline-flex.justify-center.rounded-md.border.border-gray-300.shadow-sm.px-4.py-2.bg-white.text-base.font-medium.text-gray-700.hover_bg-gray-50.focus_outline-none.focus_ring-2.focus_ring-offset-2.focus_ring-brand-500.sm_mt-0.sm_ml-3.sm_w-auto.sm_text-sm(type="button" @click="open = false") Cancel

      script.
        // AlpineJS component logic for the create task modal
        document.addEventListener('alpine:init', () => {
          Alpine.data('createTaskForm', () => ({
            // Handled inline above for simplicity
          }));
        });

        async function createTask(e) {
          const form = e.target;
          const data = {
            title: form.__x.$data.title,
            description: form.__x.$data.description,
            priority: form.__x.$data.priority,
            listId: '#{currentList ? currentList.id : ""}'
          };

          try {
            const res = await fetch('/api/tasks', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
            });
            if (res.ok) {
              window.location.reload(); // Quick refresh for MVP
            }
          } catch (err) {
            console.error(err);
            alert('Failed to create task');
          }
        }

    //- Task Detail Modal Container
    #task-modal-container.fixed.inset-0.z-50.hidden(style="background-color: rgba(0,0,0,0.5)")
      .flex.items-center.justify-center.h-full.p-4
        div(class="bg-white rounded-xl shadow-modal w-full max-w-4xl h-[85vh] flex flex-col relative")
          button#close-modal.absolute.top-4.right-4.text-gray-400.hover_text-gray-600
            svg.w-6.h-6(fill="none" stroke="currentColor" viewBox="0 0 24 24")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12")
          #task-modal-content.flex-1.overflow-y-auto.p-0

    //- Workspace Settings Modal
    #workspace-settings-modal.fixed.inset-0.z-50.hidden(style="background-color: rgba(0,0,0,0.5)")
      .flex.items-center.justify-center.h-full.p-4
        .bg-white.rounded-xl.shadow-modal.w-full.max-w-lg
          .flex.items-center.justify-between.px-6.pt-6.pb-4.border-b.border-gray-100
            h3.text-lg.font-semibold.text-gray-900 Workspace Settings
            button.text-gray-400.hover_text-gray-600.transition-colors(onclick="closeWorkspaceSettings()")
              svg.w-5.h-5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12")

          .px-6.py-5.space-y-6
            //- Rename workspace
            div
              label.text-sm.font-medium.text-gray-700.block.mb-2 Workspace Name
              .flex.gap-2
                input#ws-name-input.flex-1.form-input(
                  type="text"
                  value=currentWorkspace ? currentWorkspace.name : ''
                  placeholder="Workspace name"
                )
                button.px-4.py-2.bg-brand-600.text-white.text-sm.font-medium.rounded-md.hover_bg-brand-700.transition-colors(
                  onclick=`saveWorkspaceName('${currentWorkspace ? currentWorkspace.id : ''}')`
                ) Save

            //- Manage Members
            div
              h4.text-sm.font-medium.text-gray-700.mb-3 Members
              #ws-members-list.space-y-2
                if workspaceMembers && workspaceMembers.length > 0
                  each member in workspaceMembers
                    .flex.items-center.gap-3.p-2.rounded-lg.hover_bg-gray-50(data-member-id=member.id)
                      .avatar.w-8.h-8.flex-shrink-0(style=`background-color: ${member.avatar_color}`)
                        | #{member.name.charAt(0).toUpperCase()}
                      .flex-1.min-w-0
                        p.text-sm.font-medium.text-gray-800.truncate= member.name
                        p.text-xs.text-gray-400= member.email
                      if currentUser && member.id !== currentUser.id
                        button.text-xs.px-2.py-1.text-red-500.border.border-red-200.rounded.hover_bg-red-50.transition-colors(
                          onclick=`removeMember('${currentWorkspace ? currentWorkspace.id : ''}', '${member.id}', this.closest('[data-member-id]'))`
                        ) Remove
                      else
                        span.text-xs.text-gray-400.px-2 You
                else
                  p.text-sm.text-gray-500 No members yet.

            //- Danger Zone
            .border-t.border-red-100.pt-4
              h4.text-sm.font-semibold.text-red-600.mb-2 Danger Zone
              p.text-xs.text-gray-500.mb-3 Deleting a workspace is permanent and cannot be undone.
              button.px-4.py-2.bg-red-600.text-white.text-sm.font-medium.rounded-md.hover_bg-red-700.transition-colors(
                onclick=`deleteWorkspace('${currentWorkspace ? currentWorkspace.id : ''}')`
              ) Delete Workspace

    //- Global App Scripts
    script(src="/js/app.js")
    block scripts
